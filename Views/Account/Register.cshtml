@model RegisterViewModel
@{
    Layout = null;
}
<!DOCTYPE html>
<html lang="en">
<head>
    <meta charset="utf-8" />
    <meta name="viewport" content="width=device-width, initial-scale=1, shrink-to-fit=no" />
    <title>Register - Infass-RIVERA</title>
    <!-- Favicon-->
    <link rel="icon" type="image/x-icon" href="~/assets/favicon.ico" />
    <!-- Font Awesome icons (free version)-->
    <script src="https://use.fontawesome.com/releases/v6.3.0/js/all.js" crossorigin="anonymous"></script>
    <!-- Google fonts-->
    <link href="https://fonts.googleapis.com/css?family=Montserrat:400,700" rel="stylesheet" type="text/css" />
    <link href="https://fonts.googleapis.com/css?family=Lato:400,700,400italic,700italic" rel="stylesheet" type="text/css" />
    <!-- Core theme CSS (includes Bootstrap)-->
    <link href="~/css/site.css" rel="stylesheet" />
    <!-- Auth pages CSS (standalone, no site navigation) -->
    <link href="~/css/auth.css" rel="stylesheet" />
</head>
<body class="auth-body">
    <div class="auth-shell">
        <div class="auth-flip-card">
            <!-- Colored CTA side -->
            <div class="auth-flip-panel">
                <h2>Welcome Back!</h2>
                <p>To keep connected with us please login with your personal info.</p>
                <a class="auth-flip-btn" asp-controller="Account" asp-action="Login" asp-route-returnUrl="@ViewData["ReturnUrl"]">Sign In</a>
            </div>

            <!-- White form side -->
            <div class="auth-flip-form-side">
                <h2 class="auth-flip-heading">Create Account</h2>

                <!-- NOTE: This form does not submit to the server yet.
                     Clicking "Sign Up" shows an alert with what was entered
                     and keeps the user on this page with their input intact,
                     as requested. Swap the button back to type="submit" and
                     remove the onclick handler when you're ready to wire it
                     up to the real Register action. -->
                <form id="registerPreviewForm" novalidate>
                    <div id="registerValidationSummary" class="text-danger mb-3 text-center"></div>

                    <div class="auth-field">
                        <i class="fas fa-user"></i>
                        <input id="regFullName" asp-for="FullName" class="form-control" placeholder="Name" autocomplete="name" autofocus />
                    </div>

                    <div class="auth-field">
                        <i class="fas fa-envelope"></i>
                        <input id="regEmail" asp-for="Email" class="form-control" placeholder="Email" autocomplete="email" />
                    </div>

                    <div class="auth-field">
                        <i class="fas fa-lock"></i>
                        <input id="regPassword" asp-for="Password" class="form-control" placeholder="Password" autocomplete="new-password" />
                    </div>

                    <div class="auth-field">
                        <i class="fas fa-lock"></i>
                        <input id="regConfirmPassword" asp-for="ConfirmPassword" class="form-control" placeholder="Confirm Password" autocomplete="new-password" />
                    </div>

                    <button type="button" id="registerPreviewBtn" class="btn auth-submit-btn">Sign Up</button>
                </form>
            </div>
        </div>
    </div>

    <!-- Bootstrap core JS-->
    <script src="https://cdn.jsdelivr.net/npm/bootstrap@5.2.3/dist/js/bootstrap.bundle.min.js"></script>
    <!-- Core theme JS-->
    <script src="~/js/site.js"></script>

    <script>
        document.getElementById('registerPreviewBtn').addEventListener('click', function () {
            var name = document.getElementById('regFullName').value.trim();
            var email = document.getElementById('regEmail').value.trim();
            var password = document.getElementById('regPassword').value;
            var confirmPassword = document.getElementById('regConfirmPassword').value;
            var summary = document.getElementById('registerValidationSummary');

            if (!name || !email || !password || !confirmPassword) {
                summary.textContent = 'Please fill in all fields.';
                return;
            }

            if (password !== confirmPassword) {
                summary.textContent = 'Password and confirmation password do not match.';
                return;
            }

            summary.textContent = '';

            alert(
                'Entered details:\n\n' +
                'Name: ' + name + '\n' +
                'Email: ' + email + '\n' +
                'Password: ' + password
            );
        });
    </script>
</body>
</html>